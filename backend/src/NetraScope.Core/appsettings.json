{
  "ConnectionStrings": {
    "NetraScope": "Host=localhost;Port=5432;Database=netrascope;Username=postgres;Password=password"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Alerting": {
    "Enabled": true,
    "CpuThresholdPct": 90,
    "CpuSustainedMinutes": 5,
    "MemoryThresholdPct": 90,
    "DiskThresholdPct": 85,
    "OfflineMinutes": 2,
    "WebhookUrls": []
  },
  "AllowedHosts": "*",
  "Auth": {
    "Jwt": {
      "Secret": "CHANGE_ME_DEV_ONLY_REPLACE_WITH_A_LONG_RANDOM_SECRET",
      "Issuer": "NetraScope",
      "Audience": "NetraScope",
      "ExpiryMinutes": 60
    }
  },
  "Metrics": {
    "RateLimit": {
      "PermitLimit": 600,
      "WindowSeconds": 60
    }
  }
}
