<?xml version="1.0" encoding="utf-8"?>
<!--
  IIS hosting config for the NetraScope.Core ASP.NET Core app.
  Copy this file (or merge it) into the IIS site's physical path, next to
  NetraScope.Core.dll, after running `dotnet publish`.

  Requires the ASP.NET Core Hosting Bundle (incl. ASP.NET Core Module V2)
  to be installed on the IIS server. See ../deploy/README.md.
-->
<configuration>
  <location path="." inheritInChildApplications="false">
    <system.webServer>
      <handlers>
        <add name="aspNetCore" path="*" verb="*" modules="AspNetCoreModuleV2" resourceType="Unspecified" />
      </handlers>
      <aspNetCore processPath="dotnet"
                  arguments=".\NetraScope.Core.dll"
                  stdoutLogEnabled="true"
                  stdoutLogFile=".\logs\stdout"
                  hostingModel="inprocess">
        <environmentVariables>
          <environmentVariable name="ASPNETCORE_ENVIRONMENT" value="Production" />

          <!-- Points at the production database. Replace HOST/PORT/DB/USER/PASSWORD
               with the credentials for the (different) database server you're
               connecting this deployment to. -->
          <environmentVariable name="ConnectionStrings__NetraScope"
                                value="Host=DB_HOST;Port=5432;Database=netrascope;Username=DB_USER;Password=DB_PASSWORD" />

          <!-- Long random secret (32+ chars), must match across app restarts. -->
          <environmentVariable name="Auth__Jwt__Secret" value="REPLACE_WITH_A_LONG_RANDOM_SECRET" />

          <!-- Origin(s) the frontend is served from, e.g. https://netrascope.example.com -->
          <environmentVariable name="AllowedHosts" value="https://YOUR_FRONTEND_ORIGIN" />
        </environmentVariables>
      </aspNetCore>
    </system.webServer>
  </location>
</configuration>
