# Copy to .env and adjust before running `docker compose up`.

# PostgreSQL password (used by db, migrate, and backend).
POSTGRES_PASSWORD=password

# JWT signing secret, at least 32 random characters.
JWT_SECRET=CHANGE_ME_DEV_ONLY_REPLACE_WITH_A_LONG_RANDOM_SECRET

# Origin the dashboard is served from (used for CORS).
FRONTEND_ORIGIN=http://localhost:8081

# Host port for the reverse proxy (single entry point for frontend + API).
PROXY_PORT=8081

# Leave empty so the frontend calls the API via relative paths through the proxy.
VITE_API_BASE_URL=
